Ciao! Da Senior Full Stack Developer, apprezzo molto la struttura del tuo progetto. Un'architettura a servizi separati, containerizzata con Docker, è l'approccio ideale per scalabilità e manutenibilità.
Ho progettato questa soluzione focalizzandomi su un MVP (Minimum Viable Product) robusto. Per il frontend ho optato per HTML/CSS/JS puro (Vanilla JS) per mantenere il pacchetto leggero, facilmente testabile e senza la necessità di configurare un bundler come Webpack o Vite in questa fase iniziale, ma con una struttura pronta per essere convertita in React se necessario.
Ecco la struttura completa del tuo progetto.

Struttura delle Cartelle
Crea una cartella radice chiamata multi-calendar-app e organizzala in questo modo:

Plaintext


multi-calendar-app/
├── docker-compose.yml
├── db/
│   └── init.sql
├── backend/
│   ├── Dockerfile
│   ├── package.json
│   └── server.js
└── frontend/
    ├── Dockerfile
    ├── index.html
    ├── style.css
    └── app.js


1. Database (/db)
Iniziamo con lo schema SQL. Sfrutteremo l'inizializzazione automatica di MySQL in Docker.
db/init.sql

SQL


CREATE DATABASE IF NOT EXISTS calendar_db;
USE calendar_db;

CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL -- NB: In produzione, usare bcrypt!
);

CREATE TABLE calendars (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    name ENUM('Ufficio', 'Personale', 'Padre Pio') NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE events (
    id INT AUTO_INCREMENT PRIMARY KEY,
    calendar_id INT NOT NULL,
    title VARCHAR(100) NOT NULL,
    event_date DATE NOT NULL,
    event_time TIME,
    description TEXT,
    FOREIGN KEY (calendar_id) REFERENCES calendars(id) ON DELETE CASCADE
);

-- Dati Mock iniziali
INSERT INTO users (username, password) VALUES ('mario', 'password123');
INSERT INTO calendars (user_id, name) VALUES (1, 'Ufficio'), (1, 'Personale'), (1, 'Padre Pio');
INSERT INTO events (calendar_id, title, event_date, event_time, description) 
VALUES (1, 'Riunione Team', CURDATE(), '10:00:00', 'Sincronizzazione settimanale');


2. Backend (/backend)
Il backend Node.js espone le API REST, gestisce il JWT e fornisce il "Pensiero del giorno" di Padre Pio.
backend/package.json

JSON


{
  "name": "calendar-backend",
  "version": "1.0.0",
  "main": "server.js",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.3.3"
  }
}


backend/Dockerfile

Dockerfile


FROM node:18-alpine
WORKDIR /usr/src/app
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 3000
CMD ["node", "server.js"]


backend/server.js

JavaScript


const express = require('express');
const mysql = require('mysql2/promise');
const jwt = require('jsonwebtoken');
const cors = require('cors');

const app = express();
app.use(cors());
app.use(express.json());

const JWT_SECRET = process.env.JWT_SECRET || 'super_secret_key';

// Connessione DB con retry (utile per Docker)
let pool;
async function connectDB() {
    try {
        pool = mysql.createPool({
            host: process.env.DB_HOST,
            user: process.env.DB_USER,
            password: process.env.DB_PASSWORD,
            database: process.env.DB_NAME,
            waitForConnections: true
        });
        console.log("Connesso al database MySQL.");
    } catch (err) {
        console.error("Errore di connessione DB, riprovo in 5 sec...", err);
        setTimeout(connectDB, 5000);
    }
}
connectDB();

// Middleware di Autenticazione
const authenticateToken = (req, res, next) => {
    const token = req.headers['authorization']?.split(' ')[1];
    if (!token) return res.sendStatus(401);
    jwt.verify(token, JWT_SECRET, (err, user) => {
        if (err) return res.sendStatus(403);
        req.user = user;
        next();
    });
};

// 1. Login Endpoint
app.post('/api/login', async (req, res) => {
    const { username, password } = req.body;
    const [rows] = await pool.query('SELECT * FROM users WHERE username = ? AND password = ?', [username, password]);
    
    if (rows.length > 0) {
        const user = rows[0];
        const token = jwt.sign({ id: user.id, username: user.username }, JWT_SECRET, { expiresIn: '2h' });
        res.json({ token });
    } else {
        res.status(401).json({ error: 'Credenziali non valide' });
    }
});

// 2. Ottieni Calendari dell'utente
app.get('/api/calendars', authenticateToken, async (req, res) => {
    const [rows] = await pool.query('SELECT * FROM calendars WHERE user_id = ?', [req.user.id]);
    res.json(rows);
});

// 3. CRUD Eventi (GET)
app.get('/api/events/:calendar_id', authenticateToken, async (req, res) => {
    // Aggiungi filtri view (giorno, mese, anno) via query string se necessario
    const [rows] = await pool.query('SELECT * FROM events WHERE calendar_id = ? ORDER BY event_date ASC', [req.params.calendar_id]);
    res.json(rows);
});

// 4. CRUD Eventi (POST)
app.post('/api/events', authenticateToken, async (req, res) => {
    const { calendar_id, title, event_date, event_time, description } = req.body;
    await pool.query('INSERT INTO events (calendar_id, title, event_date, event_time, description) VALUES (?, ?, ?, ?, ?)', 
        [calendar_id, title, event_date, event_time, description]);
    res.status(201).json({ message: 'Evento creato' });
});

// 5. Funzione Mock: Pensiero di Padre Pio
app.get('/api/padrepio/quote', authenticateToken, (req, res) => {
    const quotes = [
        "Prega, spera e non ti agitare.",
        "Il dubbio è il più grande nemico della fede.",
        "Amate la Madonna e fatela amare.",
        "La preghiera è la migliore arma che abbiamo."
    ];
    // Seleziona una frase basata sul giorno dell'anno
    const dayOfYear = Math.floor((new Date() - new Date(new Date().getFullYear(), 0, 0)) / 1000 / 60 / 60 / 24);
    const dailyQuote = quotes[dayOfYear % quotes.length];
    res.json({ quote: dailyQuote, event: "Santo Rosario Serale" });
});

app.listen(3000, () => console.log('Backend in ascolto sulla porta 3000'));


3. Frontend (/frontend)
Un'interfaccia pulita con Nginx. Ho implementato una logica che filtra visivamente gli eventi per vista (Giorno/Mese/Anno).
frontend/Dockerfile

Dockerfile


FROM nginx:alpine
COPY . /usr/share/nginx/html
EXPOSE 80


frontend/index.html

HTML


<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Multi-Calendar App</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="login-container">
        <h2>Login</h2>
        <input type="text" id="username" placeholder="Username (es. mario)">
        <input type="password" id="password" placeholder="Password (es. password123)">
        <button onclick="login()">Entra</button>
    </div>

    <div id="app-container" style="display: none;">
        <header>
            <h1>I Miei Calendari</h1>
            <button onclick="logout()">Logout</button>
        </header>
        
        <div class="controls">
            <select id="calendar-select" onchange="loadEvents()"></select>
            <div class="views">
                <button onclick="changeView('day')">Giorno</button>
                <button onclick="changeView('month')">Mese</button>
                <button onclick="changeView('year')">Anno</button>
            </div>
        </div>

        <div id="padrepio-banner" style="display: none;">
            <h3>Pensiero del Giorno</h3>
            <p id="pp-quote"></p>
            <small id="pp-event"></small>
        </div>

        <div id="events-list"></div>
    </div>

    <script src="app.js"></script>
</body>
</html>


