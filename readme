frontend/app.js

JavaScript


const API_URL = 'http://localhost:3000/api';
let token = localStorage.getItem('token');
let currentCalendars = [];
let currentEvents = [];
let currentView = 'month'; // default

if (token) showApp();

async function login() {
    const u = document.getElementById('username').value;
    const p = document.getElementById('password').value;
    const res = await fetch(`${API_URL}/login`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: u, password: p })
    });
    if (res.ok) {
        const data = await res.json();
        token = data.token;
        localStorage.setItem('token', token);
        showApp();
    } else alert('Login fallito');
}

function logout() {
    localStorage.removeItem('token');
    location.reload();
}

async function showApp() {
    document.getElementById('login-container').style.display = 'none';
    document.getElementById('app-container').style.display = 'block';
    await loadCalendars();
}

async function loadCalendars() {
    const res = await fetch(`${API_URL}/calendars`, { headers: { 'Authorization': `Bearer ${token}` } });
    currentCalendars = await res.json();
    const select = document.getElementById('calendar-select');
    select.innerHTML = currentCalendars.map(c => `<option value="${c.id}" data-name="${c.name}">${c.name}</option>`).join('');
    loadEvents();
}

async function loadEvents() {
    const select = document.getElementById('calendar-select');
    const calId = select.value;
    const calName = select.options[select.selectedIndex].getAttribute('data-name');
    
    // Gestione Padre Pio Banner
    const ppBanner = document.getElementById('padrepio-banner');
    if (calName === 'Padre Pio') {
        const ppRes = await fetch(`${API_URL}/padrepio/quote`, { headers: { 'Authorization': `Bearer ${token}` } });
        const ppData = await ppRes.json();
        document.getElementById('pp-quote').innerText = `"${ppData.quote}"`;
        document.getElementById('pp-event').innerText = `Evento suggerito: ${ppData.event}`;
        ppBanner.style.display = 'block';
    } else {
        ppBanner.style.display = 'none';
    }

    const res = await fetch(`${API_URL}/events/${calId}`, { headers: { 'Authorization': `Bearer ${token}` } });
    currentEvents = await res.json();
    renderEvents();
}

function changeView(view) {
    currentView = view;
    renderEvents();
}

function renderEvents() {
    const list = document.getElementById('events-list');
    const today = new Date();
    
    // Filtro mock lato frontend per semplicità. In produzione, usare query SQL.
    const filtered = currentEvents.filter(e => {
        const edate = new Date(e.event_date);
        if (currentView === 'day') return edate.toDateString() === today.toDateString();
        if (currentView === 'month') return edate.getMonth() === today.getMonth() && edate.getFullYear() === today.getFullYear();
        if (currentView === 'year') return edate.getFullYear() === today.getFullYear();
        return true;
    });

    if (filtered.length === 0) {
        list.innerHTML = '<p>Nessun evento per questa vista.</p>';
        return;
    }

    list.innerHTML = filtered.map(e => `
        <div class="event-card">
            <h4>${e.title}</h4>
            <p><strong>${new Date(e.event_date).toLocaleDateString('it-IT')}</strong> - ${e.event_time || 'Tutto il giorno'}</p>
            <p>${e.description || ''}</p>
        </div>
    `).join('');
}


4. Docker Compose (docker-compose.yml)
Questo file orchestra il DB, il Backend e il Frontend.

YAML


version: '3.8'

services:
  db:
    image: mysql:8.0
    container_name: calendar_db
    environment:
      MYSQL_ROOT_PASSWORD: rootpassword
      MYSQL_DATABASE: calendar_db
    ports:
      - "3306:3306"
    volumes:
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql

  backend:
    build: ./backend
    container_name: calendar_backend
    ports:
      - "3000:3000"
    environment:
      - DB_HOST=db
      - DB_USER=root
      - DB_PASSWORD=rootpassword
      - DB_NAME=calendar_db
      - JWT_SECRET=my_super_secret_key
    depends_on:
      - db

  frontend:
    build: ./frontend
    container_name: calendar_frontend
    ports:
      - "8080:80"
    depends_on:
      - backend


Come Avviare il Progetto
Assicurati che Docker Desktop sia in esecuzione.
Apri il terminale nella cartella multi-calendar-app.
Esegui il comando:
Bash
docker-compose up --build


Vai su http://localhost:8080 dal tuo browser.
Fai il login con Username: mario, Password: password123.
Ti piacerebbe che estendessi il codice aggiungendo un modulo specifico per l'inserimento di nuovi eventi dal frontend?
